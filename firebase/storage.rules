rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function validFile() { return request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*|application/pdf'); }
    function isAdmin() {
      return signedIn() && firestore.exists(/databases/(default)/documents/users/$(request.auth.uid)) &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role in ["admin", "superAdmin"];
    }

    match /payment-proofs/{userId}/{fileName} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow write: if signedIn() && request.auth.uid == userId && validFile();
    }

    match /signal-charts/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validFile();
    }

    match /journal-screenshots/{userId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == userId && validFile();
    }

    match /resource-files/{fileName} {
      allow read: if true;
      allow write: if isAdmin() && validFile();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
