rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    function validFile() { return request.resource.size < 10 * 1024 * 1024 && request.resource.contentType.matches('image/.*|application/pdf'); }

    match /payment-proofs/{userId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == userId && validFile();
    }

    match /signal-charts/{fileName} {
      allow read: if true;
      allow write: if signedIn() && validFile();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
