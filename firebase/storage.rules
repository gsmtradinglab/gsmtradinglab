rules_version='2';service firebase.storage{match /b/{bucket}/o{function signedIn(){return request.auth!=null}match /paymentProofs/{uid}/{file}{allow read,write:if signedIn()&&request.auth.uid==uid}match /signals/{file}{allow read:if true;allow write:if signedIn()}match /resources/{file}{allow read:if true;allow write:if signedIn()}match /{all=**}{allow read,write:if false}}}
