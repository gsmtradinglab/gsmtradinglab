rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() { return request.auth != null; }
    match /payment-proofs/{userId}/{fileName} {
      allow read, write: if signedIn() && request.auth.uid == userId && request.resource.size < 10 * 1024 * 1024;
    }
    match /public/{fileName} { allow read: if true; allow write: if signedIn(); }
    match /{allPaths=**} { allow read, write: if false; }
  }
}
