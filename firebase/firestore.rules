rules_version='2';service cloud.firestore{match /databases/{database}/documents{function signedIn(){return request.auth!=null}function userDoc(){return get(/databases/$(database)/documents/users/$(request.auth.uid))}function isOwner(uid){return signedIn()&&request.auth.uid==uid}function isAdmin(){return signedIn()&&(userDoc().data.role in ['superAdmin','admin','supportManager','contentManager','signalManager','paymentManager'])}function isSuperAdmin(){return signedIn()&&userDoc().data.role=='superAdmin'}function hasPremium(){return signedIn()&&(userDoc().data.courseAccess in ['premium','online','physical'])}match /users/{uid}{allow create:if isOwner(uid);allow read:if isOwner(uid)||isAdmin();allow update:if (isOwner(uid)&&!('role' in request.resource.data.diff(resource.data).changedKeys())&&!('courseAccess' in request.resource.data.diff(resource.data).changedKeys())&&!('paymentStatus' in request.resource.data.diff(resource.data).changedKeys()))||isAdmin();allow delete:if isSuperAdmin()}match /registrations/{id}{allow create:if signedIn()&&request.resource.data.userId==request.auth.uid;allow read:if isAdmin()||isOwner(resource.data.userId);allow update,delete:if isAdmin()}match /signals/{id}{allow read:if resource.data.visibility=='public'||(signedIn()&&resource.data.visibility=='loggedIn')||(hasPremium()&&resource.data.visibility=='premium')||(signedIn()&&resource.data.visibility=='selected'&&request.auth.uid in resource.data.selectedUserIds)||isAdmin();allow create,update,delete:if isAdmin()}match /demoAccounts/{uid}{allow create,read,update:if isOwner(uid)||isAdmin();allow delete:if isSuperAdmin()}match /demoTrades/{id}{allow create:if signedIn()&&request.resource.data.userId==request.auth.uid;allow read,update,delete:if isAdmin()||isOwner(resource.data.userId)}match /tradingJournals/{id}{allow create:if signedIn()&&request.resource.data.userId==request.auth.uid;allow read,update,delete:if isAdmin()||isOwner(resource.data.userId)}match /supportTickets/{id}{allow create:if signedIn()||request.resource.data.userId=='guest';allow read:if isAdmin()||isOwner(resource.data.userId);allow update,delete:if isAdmin()}match /accountManagementInquiries/{id}{allow create:if signedIn()||request.resource.data.userId=='guest';allow read:if isAdmin()||isOwner(resource.data.userId);allow update,delete:if isAdmin()}match /websiteSettings/{id}{allow read:if true;allow write:if isAdmin()}match /{document=**}{allow read,write:if false}}}
